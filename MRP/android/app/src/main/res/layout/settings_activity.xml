<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/settings_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:text="MRP - Mobile Relocation Provider" />

    <TextView
        android:id="@+id/settings_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:lineSpacingExtra="4dp"
        android:text="This service allows MRP to detect when your device is locked or unlocked.\n\nWhen your device is unlocked while monitoring is active, MRP may capture a photo using the front camera to help identify who accessed your device.\n\nMRP respects your privacy - photos are stored locally and only accessible within the app." />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:text="How to use:" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:text="1. Enable this service in Accessibility settings\n2. Start monitoring from the MRP app\n3. Lock and unlock your device\n4. Check captured photos in the app" />

</LinearLayout>