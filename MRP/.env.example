# Firebase Configuration (from Firebase Console → Project settings)
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id
PUBLIC_FIREBASE_MEASUREMENT_ID=

# Realtime Database URL (Firebase Console → Realtime Database)
# Example: https://mobileresilienceplatform-default-rtdb.firebaseio.com
PUBLIC_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com

# Google Sign-In — Web client ID (not Android client)
PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# NestJS API (optional)
# PORT=3000
# MRP_API_BASE_URL=http://10.0.2.2:3000/v1

APP_OS=android
